[MACRO] DENO_HOSTNAME %out_ptr, %out_len, %out_status
    __h_ptr_slot = stack_alloc 8
    __h_len_slot = stack_alloc 8
    %out_status = call @sa_deno_plugin_hostname(&__h_ptr_slot, &__h_len_slot)
    %out_ptr = load __h_ptr_slot+0 as ptr
    %out_len = load __h_len_slot+0 as u64
[END_MACRO]


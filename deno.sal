    %out_status = call @sa_std_process_spawn_stream(&%argv, %argv_len, &__deno_spawn_proc_slot_%out_process, &__deno_spawn_stdout_slot_%out_stdout, &__deno_spawn_stderr_slot_%out_stderr)
    %out_process = load __deno_spawn_proc_slot_%out_process+0 as u64
    %out_stdout = load __deno_spawn_stdout_slot_%out_stdout+0 as u64
    %out_stderr = load __deno_spawn_stderr_slot_%out_stderr+0 as u64
[END_MACRO]

[MACRO] DENO_COMMAND_SPAWN_STREAM_CWD %out_status, %out_process, %out_stdout, %out_stderr, %argv, %argv_len, %cwd, %cwd_len
    __deno_spawn_cwd_proc_slot_%out_process = stack_alloc 8

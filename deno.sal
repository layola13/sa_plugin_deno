[MACRO] DENO_STDOUT_WRITE %out_status, %data, %data_len
    __deno_stdout_handle = call @sa_io_stdout()
    %out_status = call @sa_io_write_all(__deno_stdout_handle, &%data, %data_len)
    !__deno_stdout_handle
[END_MACRO]


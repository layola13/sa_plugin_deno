    __deno_spawn_cwd_stderr_slot_%out_stderr = stack_alloc 8
    %out_status = call @sa_std_process_spawn_stream_cwd(&%argv, %argv_len, &%cwd, %cwd_len, &__deno_spawn_cwd_proc_slot_%out_process, &__deno_spawn_cwd_stdout_slot_%out_stdout, &__deno_spawn_cwd_stderr_slot_%out_stderr)
    %out_process = load __deno_spawn_cwd_proc_slot_%out_process+0 as u64
    %out_stdout = load __deno_spawn_cwd_stdout_slot_%out_stdout+0 as u64
    %out_stderr = load __deno_spawn_cwd_stderr_slot_%out_stderr+0 as u64
[END_MACRO]

[MACRO] DENO_COMMAND_WAIT %out_status, %out_code, %process
    __deno_code_slot_%out_code = stack_alloc 4
    %out_status = call @sa_std_process_wait(%process, &__deno_code_slot_%out_code)
    %out_code = load __deno_code_slot_%out_code+0 as u32
[END_MACRO]
